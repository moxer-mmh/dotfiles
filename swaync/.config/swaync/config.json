{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,
  "fit-media-player-actions": true,
  "notification-window-width": 400,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "control-center-width": 420,
  "control-center-height": 700,
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "app-name": "example"
    }
  },
  "widgets": [
    "title",
    "mpris",
    "buttons-grid",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "  Notifications",
      "clear-all-button": true,
      "button-text": "󰆴 Clear"
    },
    "dnd": {
      "text": "  Do Not Disturb"
    },
    "mpris": {
      "image-size": 80,
      "image-radius": 8
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰤨",
          "command": "nmcli radio wifi $(nmcli radio wifi | grep -q enabled && echo off || echo on)"
        },
        {
          "label": "󰂯",
          "command": "rfkill toggle bluetooth"
        },
        {
          "label": "󰂛",
          "command": "swaync-client -d"
        },
        {
          "label": "󰖔",
          "command": "~/.config/waybar/scripts/nightlight.sh toggle"
        },
        {
          "label": "󰅶",
          "command": "~/.config/waybar/scripts/caffeine.sh toggle"
        },
        {
          "label": "󰸉",
          "command": "~/.config/theme/scripts/theme-picker.sh"
        },
        {
          "label": "󰸏",
          "command": "~/.config/hypr/scripts/wallpaper/wallpaper-picker.sh"
        },
        {
          "label": "󰒍",
          "command": "echo next > /tmp/wallpaper-daemon.pipe"
        },
        {
          "label": "󰐥",
          "command": "~/.config/waybar/scripts/power.sh"
        },
        {
          "label": "󰌾",
          "command": "hyprlock --immediate"
        }
      ]
    },
    "notifications": {
      "notification-icon-size": 64,
      "notification-body-image-height": 100,
      "notification-body-image-width": 200
    }
  },
  "hide-on-fullscreen": true,
  "max-notifications": 8
}
